{
  "name": "api",
  "type": "module",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "db": "workspace:*",
    "error": "workspace:*",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
