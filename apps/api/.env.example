DB_HOST=postgres
DB_PORT=5432
DB_NAME=<POSTGRES_DB>
DB_USERNAME=<POSTGRES_USER>
DB_PASSWORD=<POSTGRES_PASSWORD>
JWT_SECRET="your-secret-key"
